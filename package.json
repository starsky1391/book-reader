{
  "name": "book",
  "private": true,
  "version": "2.0.0",
  "description": "A lightweight desktop novel reader based on Electron + Vue3 + Vite",
  "author": "starsky1391",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:start": "electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "electron-store": "^11.0.2",
    "epub": "^2.1.1",
    "iconv-lite": "^0.7.2",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vfonts": "^0.0.3",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "com.book.reader",
    "productName": "Book Reader",
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "src/services/**/*",
      "dist/index.html",
      "dist/assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    }
  }
}
